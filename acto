#!/usr/bin/env bash
set -e

REQUIRED_NODE_VERSION=24
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure the right Node.js version is available via fnm or nvm.
# Install only if the required version isn't already installed.
ensure_node() {
    if command -v fnm &> /dev/null; then
        eval "$(fnm env)"
        if ! fnm list | grep -q "v${REQUIRED_NODE_VERSION}\."; then
            echo "Installing Node.js ${REQUIRED_NODE_VERSION} via fnm..." >&2
            fnm install "$REQUIRED_NODE_VERSION"
        fi
        fnm use "$REQUIRED_NODE_VERSION" &> /dev/null
    elif command -v nvm &> /dev/null; then
        if ! nvm ls "$REQUIRED_NODE_VERSION" &> /dev/null; then
            echo "Installing Node.js ${REQUIRED_NODE_VERSION} via nvm..." >&2
            nvm install "$REQUIRED_NODE_VERSION"
        else
            nvm use "$REQUIRED_NODE_VERSION" &> /dev/null
        fi
    elif [ -f "$HOME/.nvm/nvm.sh" ]; then
        source "$HOME/.nvm/nvm.sh"
        if ! nvm ls "$REQUIRED_NODE_VERSION" &> /dev/null; then
            echo "Installing Node.js ${REQUIRED_NODE_VERSION} via nvm..." >&2
            nvm install "$REQUIRED_NODE_VERSION"
        else
            nvm use "$REQUIRED_NODE_VERSION" &> /dev/null
        fi
    fi
}

ensure_node

# Check Node.js is installed and meets version requirement
if ! command -v node &> /dev/null; then
    echo "Error: Node.js is not installed" >&2
    echo "Please install fnm or nvm, then run this script again" >&2
    exit 1
fi

NODE_VERSION=$(node -v | cut -d'v' -f2 | cut -d'.' -f1)
if [ "$NODE_VERSION" -lt "$REQUIRED_NODE_VERSION" ]; then
    echo "Error: Node.js ${REQUIRED_NODE_VERSION}.x or later is required (current: $(node -v))" >&2
    exit 1
fi

# Auto-build after clean checkout
if [ ! -d "$SCRIPT_DIR/dist" ]; then
    echo "First run: installing dependencies and building..." >&2
    (cd "$SCRIPT_DIR" && npm install && npm run build) >&2
fi

exec node "$SCRIPT_DIR/dist/index.js" "$@"
