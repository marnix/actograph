#!/usr/bin/env bash
set -x
set -e

REQUIRED_NODE_VERSION=24
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Install and activate Node via nvm or fnm
if command -v fnm &> /dev/null; then
    fnm install "$REQUIRED_NODE_VERSION" &> /dev/null
    eval "$(fnm env)"
    fnm use "$REQUIRED_NODE_VERSION" &> /dev/null
elif command -v nvm &> /dev/null; then
    nvm install "$REQUIRED_NODE_VERSION" &> /dev/null
    nvm use "$REQUIRED_NODE_VERSION" &> /dev/null
elif [ -f "$HOME/.nvm/nvm.sh" ]; then
    source "$HOME/.nvm/nvm.sh"
    nvm install "$REQUIRED_NODE_VERSION" &> /dev/null
    nvm use "$REQUIRED_NODE_VERSION" &> /dev/null
fi

# Check Node.js is installed
if ! command -v node &> /dev/null; then
    echo "Error: Node.js is not installed" >&2
    echo "Please install fnm or nvm, then run this script again" >&2
    exit 1
fi

# Check Node.js version
NODE_VERSION=$(node -v | cut -d'v' -f2 | cut -d'.' -f1)
if [ "$NODE_VERSION" -lt "$REQUIRED_NODE_VERSION" ]; then
    echo "Error: Node.js ${REQUIRED_NODE_VERSION}.x or later is required" >&2
    echo "Current version: $(node -v)" >&2
    exit 1
fi

# Auto-build after clean checkout
if [ ! -d "$SCRIPT_DIR/dist" ]; then
    echo "First run: installing dependencies and building..." >&2
    (cd "$SCRIPT_DIR" && npm install && npm run build) >&2
fi

# Run the CLI
exec node "$SCRIPT_DIR/dist/index.js" "$@"
