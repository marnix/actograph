{
  "name": "actograph",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "build:verify": "node -e \"import('fs').then(f=>{f.rmSync('dist',{recursive:true,force:true})})\" && tsc --build && node dist/index.js --version",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "acto": "npm run build && ./acto",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "concurrently --success all 'npm:typecheck' 'npm:format:check' 'npm:test'",
    "ci": "npm run build:verify && npm run check",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "commander": "^14.0.3",
    "cuss": "^2.2.0",
    "graphology": "^0.26.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.1.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
